# ============================================================================
# RAXA AI - Environment Configuration Example
# Copy this file to .env or .env.local and fill in your values
# ============================================================================

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/raxa
MONGODB_NAME=raxa

# Backend Server Configuration
NODE_ENV=development
PORT=8000
BACKEND_URL=http://localhost:8000

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# NEXT_PUBLIC_API_URL is the base URL of the backend (no /api/v2 suffix).
# Frontend components append /api/v2/... themselves.
NEXT_PUBLIC_API_URL=http://localhost:8000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# API Configuration
API_VERSION=2.0.0

# JWT Configuration (for future authentication)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRY=7d

# Logging
LOG_LEVEL=debug
